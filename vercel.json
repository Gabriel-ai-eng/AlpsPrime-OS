{
  "rewrites": [
    { "source": "/jogo", "destination": "https://projeto-armor.vercel.app/" },
    { "source": "/jogo/", "destination": "https://projeto-armor.vercel.app/" },
    { "source": "/jogo/:path*", "destination": "https://projeto-armor.vercel.app/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/((?!api/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|gif|svg|ico|woff2?|mp4|webm|pdf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
