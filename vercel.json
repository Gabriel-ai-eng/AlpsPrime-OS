{
  "rewrites": [
    { "source": "/jogo", "destination": "https://projeto-armor.vercel.app/" },
    { "source": "/jogo/", "destination": "https://projeto-armor.vercel.app/" },
    { "source": "/jogo/:path*", "destination": "https://projeto-armor.vercel.app/:path*" },
    { "source": "/fkw", "destination": "https://free-kick-world.vercel.app/" },
    { "source": "/fkw/", "destination": "https://free-kick-world.vercel.app/" },
    { "source": "/fkw/:path*", "destination": "https://free-kick-world.vercel.app/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|webp|gif|svg|ico|woff2?)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
