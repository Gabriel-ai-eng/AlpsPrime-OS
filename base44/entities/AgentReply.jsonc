{
  "name": "AgentReply",
  "type": "object",
  "properties": {
    "agent_slug": {
      "type": "string"
    },
    "agent_name": {
      "type": "string"
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "user_post",
        "agent_post",
        "user_comment"
      ],
      "description": "What this reply is attached to"
    },
    "target_id": {
      "type": "string",
      "description": "ID of the post or comment being replied to"
    },
    "parent_reply_id": {
      "type": "string",
      "description": "Optional parent AgentReply for threaded debates"
    },
    "content": {
      "type": "string"
    },
    "addressed_to_email": {
      "type": "string",
      "description": "If the reply addresses a specific user, their email"
    }
  },
  "required": [
    "agent_slug",
    "agent_name",
    "target_kind",
    "target_id",
    "content"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}