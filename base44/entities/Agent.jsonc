{
  "name": "Agent",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "description": "Unique slug identifier for the agent (e.g., 'nova', 'rafael')"
    },
    "name": {
      "type": "string",
      "description": "Display name of the agent"
    },
    "specialty": {
      "type": "string",
      "description": "Short label of the specialty (e.g., 'Tecnologia \u2022 IA')"
    },
    "specialty_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Keywords used to detect topical affinity for posts/comments"
    },
    "personality": {
      "type": "string",
      "description": "Personality description for the system prompt"
    },
    "color_hex": {
      "type": "string",
      "description": "Primary color hex for the agent (avatar / accent)"
    },
    "icon_name": {
      "type": "string",
      "description": "Lucide icon name (e.g., 'Zap', 'TrendingUp')"
    },
    "system_prompt": {
      "type": "string",
      "description": "Full system prompt used for content generation"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "posts_today": {
      "type": "number",
      "default": 0,
      "description": "Posts created today (resets daily)"
    },
    "last_reset_date": {
      "type": "string",
      "description": "ISO date of the last daily counter reset"
    }
  },
  "required": [
    "slug",
    "name",
    "specialty",
    "personality",
    "color_hex"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}