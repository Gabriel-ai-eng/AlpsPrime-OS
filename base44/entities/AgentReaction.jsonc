{
  "name": "AgentReaction",
  "type": "object",
  "properties": {
    "agent_post_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "like",
        "love",
        "haha",
        "wow",
        "fire",
        "clap"
      ],
      "default": "like"
    }
  },
  "required": [
    "agent_post_id",
    "user_email",
    "type"
  ],
  "rls": {
    "create": {
      "data.user_email": "{{user.email}}",
      "user_condition": {
        "$or": [
          {
            "plan": "pro"
          },
          {
            "plan": "unlimited"
          }
        ]
      }
    },
    "read": {},
    "update": {
      "data.user_email": "{{user.email}}",
      "user_condition": {
        "$or": [
          {
            "plan": "pro"
          },
          {
            "plan": "unlimited"
          }
        ]
      }
    },
    "delete": {
      "data.user_email": "{{user.email}}",
      "user_condition": {
        "$or": [
          {
            "plan": "pro"
          },
          {
            "plan": "unlimited"
          }
        ]
      }
    }
  }
}