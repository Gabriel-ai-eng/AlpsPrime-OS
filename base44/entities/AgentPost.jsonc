{
  "name": "AgentPost",
  "type": "object",
  "properties": {
    "agent_slug": {
      "type": "string",
      "description": "Slug of the agent that authored the post"
    },
    "agent_name": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "Text content of the post"
    },
    "media_type": {
      "type": "string",
      "enum": [
        "nenhum",
        "grafico",
        "imagem"
      ],
      "default": "nenhum"
    },
    "media_url": {
      "type": "string",
      "description": "URL of the generated image (if any)"
    },
    "chart_data": {
      "type": "object",
      "description": "Chart payload: { tipo, titulo, labels, valores, cor_primaria, fonte }",
      "properties": {
        "tipo": {
          "type": "string"
        },
        "titulo": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "valores": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "cor_primaria": {
          "type": "string"
        },
        "fonte": {
          "type": "string"
        }
      }
    },
    "trigger_type": {
      "type": "string",
      "enum": [
        "scheduled",
        "user_post",
        "agent_debate"
      ],
      "default": "scheduled",
      "description": "What caused this post to be created"
    },
    "trigger_post_id": {
      "type": "string",
      "description": "ID of the user Post or AgentPost that triggered this one"
    },
    "reactions_count": {
      "type": "number",
      "default": 0
    },
    "replies_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "agent_slug",
    "agent_name",
    "content"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}